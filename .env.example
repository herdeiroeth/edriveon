# Copie para `.env` e preencha. NUNCA commite o `.env` real.

# ─── Banco de dados ──────────────────────────────────────────────────────────
# Local (Postgres):     postgresql://USUARIO@localhost:5432/edriveon?schema=public
# Railway (pooled):     postgresql://...@<host>:<port>/railway?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL="postgresql://USUARIO@localhost:5432/edriveon?schema=public"
# Conexão DIRETA (sem pooler) — usada por `prisma migrate`. Local = igual à DATABASE_URL.
DIRECT_URL="postgresql://USUARIO@localhost:5432/edriveon?schema=public"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="cole-um-segredo-aqui"
# Em produção atrás de proxy (Vercel/Railway), defina:
# AUTH_TRUST_HOST="true"
# AUTH_URL="https://seu-dominio"
